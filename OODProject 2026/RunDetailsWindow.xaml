<Window x:Class="OODProject_2026.RunDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:OODProject_2026.Helpers"
        Title="Run Details"
        Height="620"
        Width="850"
        MinHeight="560"
        MinWidth="760"
        Background="#0B0B0B"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AFAFAF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <Style x:Key="InfoValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="DarkInfoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1D1D1D"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Border Background="#111111"
                BorderBrush="#2E2E2E"
                BorderThickness="1"
                CornerRadius="16"
                Padding="16">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- COVER IMAGE -->
                <Border Grid.Column="0"
                        Background="#181818"
                        BorderBrush="#303030"
                        BorderThickness="1"
                        CornerRadius="14"
                        ClipToBounds="True">

                    <Grid>
                        <!-- Placeholder shown behind image -->
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="12">
                            <TextBlock Text="▧"
                                       Foreground="#555555"
                                       FontSize="42"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Cover unavailable"
                                       Foreground="#9F9F9F"
                                       FontSize="13"
                                       TextAlignment="Center"/>
                        </StackPanel>

                        <Image Stretch="UniformToFill"
                               helpers:ComicVineImageLoader.ImageUrl="{Binding Image.MediumUrl, TargetNullValue=''}"/>
                    </Grid>
                </Border>

                <!-- DETAILS -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- TITLE -->
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="{Binding Name}"
                                   Foreground="White"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="{Binding PublisherDisplay}"
                                   Foreground="#D34A38"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- QUICK STATS -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource DarkInfoCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Start Year"
                                           Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock Text="{Binding StartYear}"
                                           Style="{StaticResource InfoValueStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource DarkInfoCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Issues"
                                           Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock Text="{Binding CountOfIssues}"
                                           Style="{StaticResource InfoValueStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4"
                                Style="{StaticResource DarkInfoCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Source"
                                           Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock Text="ComicVine API"
                                           Style="{StaticResource InfoValueStyle}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- PEOPLE CREDITS -->
                    <Border Grid.Row="4"
                            Style="{StaticResource DarkInfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="People Credits"
                                       Style="{StaticResource InfoLabelStyle}"/>

                            <TextBlock Text="{Binding PeopleDisplay}"
                                       Style="{StaticResource InfoValueStyle}"/>
                        </StackPanel>
                    </Border>

                    <!-- SUMMARY -->
                    <Border Grid.Row="6"
                            Style="{StaticResource DarkInfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Summary"
                                       Style="{StaticResource InfoLabelStyle}"/>

                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding SummaryText}"
                                           Foreground="#EAEAEA"
                                           TextWrapping="Wrap"
                                           LineHeight="20"/>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <!-- CLOSE BUTTON -->
                    <Button Grid.Row="8"
                            Content="Close"
                            Height="34"
                            Width="110"
                            HorizontalAlignment="Right"
                            Background="#202020"
                            Foreground="White"
                            BorderBrush="#3A3A3A"
                            Click="Close_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>